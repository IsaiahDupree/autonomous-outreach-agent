# Claude AI
ANTHROPIC_API_KEY=your_claude_api_key

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# CRMLite (optional — cloud CRM sync)
CRMLITE_URL=https://your-crmlite.vercel.app
CRMLITE_API_KEY=your_crmlite_key

# Obsidian vault path (optional)
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault

# Safari Automation ports (if using local Safari services)
SAFARI_UPWORK_PORT=3104
SAFARI_LINKEDIN_PORT=3105

# Chrome CDP port
CHROME_CDP_PORT=9222

# Server
PORT=3500
