{
  "name": "autonomous-outreach-agent",
  "version": "1.0.0",
  "description": "Autonomous outreach agent for Upwork proposals and Chrome/LinkedIn prospecting — Riona-style modular architecture powered by Claude AI.",
  "main": "src/index.ts",
  "scripts": {
    "start": "npx tsc && node build/index.js",
    "dev": "ts-node src/index.ts",
    "build": "tsc && cp -r src/Agent/characters build/Agent/",
    "upwork": "ts-node src/index.ts --module upwork",
    "chrome": "ts-node src/index.ts --module chrome",
    "status": "ts-node src/index.ts --status",
    "once": "ts-node src/index.ts --once",
    "login:upwork": "ts-node src/index.ts --login --module=upwork",
    "login:linkedin": "ts-node src/index.ts --login --module=linkedin"
  },
  "keywords": [
    "automation",
    "upwork",
    "linkedin",
    "claude-ai",
    "outreach"
  ],
  "author": "IsaiahDupree",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "node-cron": "^3.0.3",
    "puppeteer": "^23.11.1",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-recaptcha": "^3.6.8",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
